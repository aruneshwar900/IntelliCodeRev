# ── PICK ONE of the database options below ──────────────────

# Option A: Neon cloud (recommended if Supabase is blocked)
# Get URL from neon.tech → your project → Connection Details
# It looks like: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Leave DB_SSL unset or set to true for Neon

# Option B: Local PostgreSQL
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/gitrev
# DB_SSL=false

# ── Redis ───────────────────────────────────────────────────
# Upstash cloud (free — recommended):
# Get from upstash.com → your database → "Redis URL" tab
UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Local Redis / Memurai:
# UPSTASH_REDIS_URL=redis://localhost:6379

# ── LLM ─────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxx       # free at console.groq.com
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-70b-versatile

# ── GitHub OAuth ─────────────────────────────────────────────
# Create at github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=any-random-string-you-make-up

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── App URLs (keep as-is for local dev) ──────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
