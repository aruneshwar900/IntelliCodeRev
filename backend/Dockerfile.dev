FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
COPY backend/package*.json ./backend/
COPY frontend/package*.json ./frontend/
COPY agents/package*.json ./agents/
COPY shared/package*.json ./shared/
RUN npm ci

COPY backend ./backend
COPY shared ./shared

EXPOSE 3001
CMD ["npm", "run", "dev", "-w", "backend"]
